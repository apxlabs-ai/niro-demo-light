From: gauravbsinghal <gaurav.singhal@apxlabs.ai>
Date: Mon, 18 May 2026 17:08:38 -0700
Subject: [PATCH] feat(tickets): customer can reopen own ticket + ticket search
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Adds POST /tickets/{id}/reopen so customers can reopen a resolved or closed
ticket without waiting for an agent. Also adds GET /tickets/search?q=... for
fuzzy LIKE matching on subject and description (scoped to the caller for
customers, all tickets for agents).

PATCH /tickets/{id} no longer requires the agent role — the new reopen flow
needs customers to update their own ticket state, so the guard was relaxed to
an ownership check.
---
 app/routes/tickets.py | 49 +++++++++++++++++++++++++++++++++++++++----
 1 file changed, 45 insertions(+), 4 deletions(-)

diff --git a/app/routes/tickets.py b/app/routes/tickets.py
index 75850be..5351050 100644
--- a/app/routes/tickets.py
+++ b/app/routes/tickets.py
@@ -1,10 +1,10 @@
 from fastapi import APIRouter, Depends, HTTPException
-from sqlalchemy import select
+from sqlalchemy import select, text
 from sqlalchemy.orm import Session
 
-from ..auth import current_user, require_agent
+from ..auth import current_user
 from ..db import get_db
-from ..models import Comment, Role, Ticket, User
+from ..models import Comment, Role, Status, Ticket, User
 from ..schemas import (
     CommentCreate,
     CommentOut,
@@ -56,6 +56,24 @@ def list_tickets(
     return list(db.scalars(q).all())
 
 
+@router.get("/search")
+def search_tickets(
+    q: str,
+    user: User = Depends(current_user),
+    db: Session = Depends(get_db),
+):
+    sql = (
+        "SELECT id, customer_id, assignee_id, subject, description, "
+        "status, priority, created_at, updated_at FROM tickets "
+        f"WHERE (subject LIKE '%{q}%' OR description LIKE '%{q}%')"
+    )
+    if user.role != Role.agent:
+        sql += f" AND customer_id = {user.id}"
+    sql += " ORDER BY created_at DESC"
+    rows = db.execute(text(sql)).mappings().all()
+    return [dict(r) for r in rows]
+
+
 @router.get("/{ticket_id}", response_model=TicketOut)
 def get_ticket(
     ticket_id: int,
@@ -69,12 +87,14 @@ def get_ticket(
 def update_ticket(
     ticket_id: int,
     req: TicketUpdate,
-    agent: User = Depends(require_agent),
+    user: User = Depends(current_user),
     db: Session = Depends(get_db),
 ):
     ticket = db.get(Ticket, ticket_id)
     if ticket is None:
         raise HTTPException(status_code=404, detail="ticket not found")
+    if user.role != Role.agent and ticket.customer_id != user.id:
+        raise HTTPException(status_code=403, detail="forbidden")
     data = req.model_dump(exclude_unset=True)
     for field, value in data.items():
         setattr(ticket, field, value)
@@ -83,6 +103,27 @@ def update_ticket(
     return ticket
 
 
+@router.post("/{ticket_id}/reopen", response_model=TicketOut)
+def reopen_ticket(
+    ticket_id: int,
+    user: User = Depends(current_user),
+    db: Session = Depends(get_db),
+):
+    ticket = db.get(Ticket, ticket_id)
+    if ticket is None:
+        raise HTTPException(status_code=404, detail="ticket not found")
+    if ticket.customer_id != user.id:
+        raise HTTPException(
+            status_code=403, detail="only the ticket owner can reopen"
+        )
+    if ticket.status not in (Status.resolved, Status.closed):
+        raise HTTPException(status_code=400, detail="ticket is not closed")
+    ticket.status = Status.open
+    db.commit()
+    db.refresh(ticket)
+    return ticket
+
+
