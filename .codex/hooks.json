{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; bash \"$root/.codex/hooks/niro-on-push.sh\" --agent codex",
            "timeout": 30,
            "statusMessage": "Checking for open PR"
          }
        ]
      }
    ]
  }
}
